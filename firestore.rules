rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── ヘルパー関数 ─────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    // workspaces ドキュメントの members マップで確認（単一ドキュメント取得時のみ使用）
    function isMember(workspaceId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/workspaces/$(workspaceId))
          .data.members[request.auth.uid] != null;
    }

    function isOwnerOrAdmin(workspaceId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/workspaces/$(workspaceId))
          .data.members[request.auth.uid] in ['owner', 'admin'];
    }

    // ── ユーザー自身のドキュメント ───────────────────────────────
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // ── ワークスペース ───────────────────────────────────────────
    // コレクション全体を取得するクエリがあるため読み取りはログイン済みで許可
    // 書き込みは API 経由（admin SDK）のみ
    match /workspaces/{workspaceId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ── サイト ───────────────────────────────────────────────────
    // コレクション全体クエリあり → 読み取りはログイン済みで許可
    // 書き込みは Cloud Functions のみ
    match /sites/{siteId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ── シナリオ ─────────────────────────────────────────────────
    match /scenarios/{scenarioId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ── アクション ───────────────────────────────────────────────
    match /actions/{actionId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ── テンプレート（クライアントから直接書き込みあり） ─────────
    match /templates/{templateId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isMember(request.resource.data.workspaceId);
      allow update, delete: if isSignedIn() && isMember(resource.data.workspaceId);
    }

    // ── メディア（クライアントから直接書き込みあり） ─────────────
    match /media/{mediaId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isMember(request.resource.data.workspaceId);
      allow update, delete: if isSignedIn() && isMember(resource.data.workspaceId);
    }

    // ── ログ（SDK → Cloud Functions → admin SDK で書き込み）──────
    match /logs/{logId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ── 日別統計（Cloud Functions が書き込み）────────────────────
    match /stats_daily/{statId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ── プラン（読み取りは認証済み、書き込みはAPIのみ）──────────
    match /plans/{planId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ── 課金情報（オーナー/管理者のみ）──────────────────────────
    match /workspace_billing/{workspaceId} {
      allow read: if isOwnerOrAdmin(workspaceId);
      allow write: if false;
    }

    // ── 利用制限オーバーライド ───────────────────────────────────
    match /workspace_limit_overrides/{workspaceId} {
      allow read: if isOwnerOrAdmin(workspaceId);
      allow write: if false;
    }

    // ── 招待（トークンで受け入れ可、書き込みはAPIのみ）──────────
    match /workspace_invites/{inviteId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ── Misocaトークン（クライアントからアクセス不可）───────────
    match /workspace_misoca_tokens/{docId} {
      allow read, write: if false;
    }

    // ── 上記以外は全拒否 ─────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
