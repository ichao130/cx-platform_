rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── ヘルパー関数 ─────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    // workspaces ドキュメントを取得してメンバー確認
    function isMember(workspaceId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/workspaces/$(workspaceId))
          .data.members[request.auth.uid] != null;
    }

    function isOwnerOrAdmin(workspaceId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/workspaces/$(workspaceId))
          .data.members[request.auth.uid] in ['owner', 'admin'];
    }

    // サイトの memberUids に自分が含まれるか（siteId 絞りクエリの分離に使う）
    // list クエリではクエリ制約(siteId定数)に対し1回だけ評価される＝get 1回。
    function isSiteMember(siteId) {
      return isSignedIn() &&
        request.auth.uid in
          get(/databases/$(database)/documents/sites/$(siteId)).data.memberUids;
    }

    // ── ユーザー自身のドキュメント ───────────────────────────────
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // ── ワークスペース ───────────────────────────────────────────
    match /workspaces/{workspaceId} {
      // メンバーのみ読み取り可（他アカウントへの漏洩を防ぐ）
      allow read: if isSignedIn() &&
        resource.data.members[request.auth.uid] != null;
      allow create: if isSignedIn() &&
        request.resource.data.members[request.auth.uid] == 'owner';
      allow update: if isOwnerOrAdmin(workspaceId);
      allow delete: if false;
    }

    // ── サイト ───────────────────────────────────────────────────
    // read: 自分が memberUids に入っている(memberUids array-contains uid クエリ) か、
    //       自ワークスペース(workspaceId == X クエリ)のメンバーのみ
    match /sites/{siteId} {
      allow read: if isSignedIn() && (
        (('memberUids' in resource.data) && (request.auth.uid in resource.data.memberUids))
        || isMember(resource.data.workspaceId)
      );
      // 作成・削除は API 経由のみ（admin SDK）
      allow create, delete: if false;
      allow update: if isSignedIn() && isOwnerOrAdmin(resource.data.workspaceId);
    }

    // ── シナリオ ─────────────────────────────────────────────────
    // read: siteId絞り(各ページ) と workspaceId絞り(ActionsPage) の2系統
    // write: 自分のワークスペースのみ（不正書き換え防止）
    match /scenarios/{scenarioId} {
      allow read: if isSiteMember(resource.data.siteId)
        || isMember(resource.data.workspaceId);
      allow create: if isSignedIn() && isMember(request.resource.data.workspaceId)
        && request.resource.data.workspaceId is string
        && request.resource.data.workspaceId.size() > 0;
      allow update: if isSignedIn() && isMember(resource.data.workspaceId)
        && request.resource.data.workspaceId == resource.data.workspaceId;
      allow delete: if isSignedIn() && isMember(resource.data.workspaceId);
    }

    // ── アクション ───────────────────────────────────────────────
    // read: workspaceId 絞り(ScenariosPage等) と siteId 絞り(ActionsPage) の2系統
    match /actions/{actionId} {
      allow read: if isMember(resource.data.workspaceId)
        || isSiteMember(resource.data.siteId);
      allow create: if isSignedIn() && isMember(request.resource.data.workspaceId)
        && request.resource.data.workspaceId is string
        && request.resource.data.workspaceId.size() > 0;
      allow update: if isSignedIn() && isMember(resource.data.workspaceId)
        && request.resource.data.workspaceId == resource.data.workspaceId;
      allow delete: if isSignedIn() && isMember(resource.data.workspaceId);
    }

    // ── テンプレート ─────────────────────────────────────────────
    // read: workspaceId 絞りクエリ → 自ワークスペースのメンバーのみ
    match /templates/{templateId} {
      allow read: if isMember(resource.data.workspaceId);
      allow create: if isSignedIn() && isMember(request.resource.data.workspaceId)
        && request.resource.data.workspaceId is string
        && request.resource.data.workspaceId.size() > 0;
      allow update: if isSignedIn() && isMember(resource.data.workspaceId)
        && request.resource.data.workspaceId == resource.data.workspaceId;
      allow delete: if isSignedIn() && isMember(resource.data.workspaceId);
    }

    // ── メディア（read: workspaceId絞り(MediaLibrary) と siteId絞り(ActionsPage) の2系統）──
    match /media/{mediaId} {
      allow read: if isMember(resource.data.workspaceId)
        || isSiteMember(resource.data.siteId);
      allow create: if isSignedIn() && isMember(request.resource.data.workspaceId)
        && request.resource.data.workspaceId is string
        && request.resource.data.workspaceId.size() > 0;
      allow update: if isSignedIn() && isMember(resource.data.workspaceId)
        && request.resource.data.workspaceId == resource.data.workspaceId;
      // 削除は Cloud Functions（deleteMedia Callable）経由のみ
      allow delete: if false;
    }

    // ── ログ（site_id 絞りクエリ → そのサイトのメンバーのみ。書き込みはFunctionsのみ）──
    match /logs/{logId} {
      allow read: if isSiteMember(resource.data.site_id);
      allow write: if false;
    }

    // ── 日別統計（siteId 絞りクエリ → そのサイトのメンバーのみ。書き込みはFunctionsのみ）
    match /stats_daily/{statId} {
      allow read: if isSiteMember(resource.data.siteId);
      allow write: if false;
    }

    // ── プラン（読み取りは認証済み、書き込みはAPIのみ）──────────
    match /plans/{planId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ── 課金情報（オーナー/管理者のみ）──────────────────────────
    match /workspace_billing/{workspaceId} {
      allow read: if isOwnerOrAdmin(workspaceId);
      allow write: if false;
    }

    // ── 利用制限オーバーライド ───────────────────────────────────
    match /workspace_limit_overrides/{workspaceId} {
      allow read: if isOwnerOrAdmin(workspaceId);
      allow write: if false;
    }

    // ── 招待（クライアント直読みなし＝API/admin SDK経由のみ。読み書きとも不可）──
    match /workspace_invites/{inviteId} {
      allow read, write: if false;
    }

    // ── Misocaトークン（クライアントからアクセス不可）───────────
    match /workspace_misoca_tokens/{docId} {
      allow read, write: if false;
    }

    // ── BOオペレーター管理（読み取りは認証済み、書き込みはスーパー管理者のみ）──
    match /ops_admins/{email} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.token.email == "iwatanabe@branberyheag.com";
    }

    // ── お知らせ（認証済みは読める、書き込みはplatform adminのみ）──
    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.token.email == "iwatanabe@branberyheag.com";
    }

    // ── 特別トライアル（platform adminのみ）──────────────────────
    match /special_trials/{trialId} {
      allow read, write: if isSignedIn() && request.auth.token.email == "iwatanabe@branberyheag.com";
    }

    // ── 上記以外は全拒否 ─────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
