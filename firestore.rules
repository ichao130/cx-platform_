rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── ヘルパー関数 ─────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    // workspace.members マップで uid を直接確認（resource.data から参照）
    function isMemberOf(members) {
      return isSignedIn() && request.auth.uid in members;
    }

    // workspaces ドキュメントを取得してメンバー確認（create 時など resource.data が無い場合）
    function isMember(workspaceId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/workspaces/$(workspaceId))
          .data.members[request.auth.uid] != null;
    }

    function isOwnerOrAdmin(workspaceId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/workspaces/$(workspaceId))
          .data.members[request.auth.uid] in ['owner', 'admin'];
    }

    // ── ユーザー自身のドキュメント ───────────────────────────────
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // ── ワークスペース ───────────────────────────────────────────
    match /workspaces/{workspaceId} {
      // 自分が members に含まれている場合のみ読み取り可
      allow read: if isSignedIn() && isMemberOf(resource.data.members);
      // 初回ログイン時の自動作成: 自分をownerとして設定する場合のみ許可
      allow create: if isSignedIn() &&
        request.resource.data.members[request.auth.uid] == 'owner';
      // 更新: オーナーまたは管理者のみ（ドメイン設定などの直接更新用）
      allow update: if isOwnerOrAdmin(workspaceId);
      // 削除: API経由のみ
      allow delete: if false;
    }

    // ── サイト ───────────────────────────────────────────────────
    match /sites/{siteId} {
      allow read: if isSignedIn() && (
        isOwnerOrAdmin(resource.data.workspaceId) ||
        !('memberUids' in resource.data) ||
        request.auth.uid in resource.data.memberUids
      );
      // 作成・削除は API 経由のみ（admin SDK）
      allow create, delete: if false;
      allow update: if isSignedIn() && isOwnerOrAdmin(resource.data.workspaceId);
    }

    // ── シナリオ ─────────────────────────────────────────────────
    match /scenarios/{scenarioId} {
      // 自分のワークスペースのみ読み取り可
      allow read: if isMember(resource.data.workspaceId);
      allow create: if isSignedIn() && isMember(request.resource.data.workspaceId)
        // workspaceId の改ざん防止
        && request.resource.data.workspaceId is string
        && request.resource.data.workspaceId.size() > 0;
      allow update: if isSignedIn() && isMember(resource.data.workspaceId)
        // workspaceId を変更不可
        && request.resource.data.workspaceId == resource.data.workspaceId;
      allow delete: if isSignedIn() && isMember(resource.data.workspaceId);
    }

    // ── アクション ───────────────────────────────────────────────
    match /actions/{actionId} {
      allow read: if isMember(resource.data.workspaceId);
      allow create: if isSignedIn() && isMember(request.resource.data.workspaceId)
        && request.resource.data.workspaceId is string
        && request.resource.data.workspaceId.size() > 0;
      allow update: if isSignedIn() && isMember(resource.data.workspaceId)
        && request.resource.data.workspaceId == resource.data.workspaceId;
      allow delete: if isSignedIn() && isMember(resource.data.workspaceId);
    }

    // ── テンプレート（クライアントから直接書き込みあり） ─────────
    match /templates/{templateId} {
      allow read: if isMember(resource.data.workspaceId);
      allow create: if isSignedIn() && isMember(request.resource.data.workspaceId)
        && request.resource.data.workspaceId is string
        && request.resource.data.workspaceId.size() > 0;
      allow update: if isSignedIn() && isMember(resource.data.workspaceId)
        && request.resource.data.workspaceId == resource.data.workspaceId;
      allow delete: if isSignedIn() && isMember(resource.data.workspaceId);
    }

    // ── メディア（クライアントから直接書き込みあり、削除はAPIのみ） ──
    match /media/{mediaId} {
      allow read: if isMember(resource.data.workspaceId);
      allow create: if isSignedIn() && isMember(request.resource.data.workspaceId)
        && request.resource.data.workspaceId is string
        && request.resource.data.workspaceId.size() > 0;
      allow update: if isSignedIn() && isMember(resource.data.workspaceId)
        && request.resource.data.workspaceId == resource.data.workspaceId;
      // 削除は Cloud Functions（deleteMedia Callable）経由のみ
      allow delete: if false;
    }

    // ── ログ（SDK → Cloud Functions → admin SDK で書き込み）──────
    match /logs/{logId} {
      allow read, write: if false;
    }

    // ── 日別統計（Cloud Functions が書き込み）────────────────────
    match /stats_daily/{statId} {
      // ワークスペースメンバーのみ読み取り可
      allow read: if isMember(resource.data.workspaceId);
      allow write: if false;
    }

    // ── プラン（読み取りは認証済み、書き込みはAPIのみ）──────────
    match /plans/{planId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ── 課金情報（オーナー/管理者のみ）──────────────────────────
    match /workspace_billing/{workspaceId} {
      allow read: if isOwnerOrAdmin(workspaceId);
      allow write: if false;
    }

    // ── 利用制限オーバーライド ───────────────────────────────────
    match /workspace_limit_overrides/{workspaceId} {
      allow read: if isOwnerOrAdmin(workspaceId);
      allow write: if false;
    }

    // ── 招待（トークンで受け入れ可、書き込みはAPIのみ）──────────
    match /workspace_invites/{inviteId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ── Misocaトークン（クライアントからアクセス不可）───────────
    match /workspace_misoca_tokens/{docId} {
      allow read, write: if false;
    }

    // ── お知らせ（認証済みは読める、書き込みはplatform adminのみ）──
    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.token.email == "iwatanabe@branberyheag.com";
    }

    // ── 特別トライアル（platform adminのみ）──────────────────────
    match /special_trials/{trialId} {
      allow read, write: if isSignedIn() && request.auth.token.email == "iwatanabe@branberyheag.com";
    }

    // ── 上記以外は全拒否 ─────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
